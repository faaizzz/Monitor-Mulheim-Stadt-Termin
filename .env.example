# Copy this file to .env and fill in your own values.
# See README.md "Notifications" section for how to obtain these from @BotFather.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# How often (ms) each notification monitor retries after a "no slot yet"
# check. Default 600000 (10 minutes) if unset.
MONITOR_INTERVAL_MS=

# How long (ms) the Supabase sync job waits after finishing one sweep of all
# 49 Anliegen before starting the next. Default 600000 (10 minutes) if unset.
SYNC_GAP_MS=

# Required by tests/availability-sync.spec.ts (the Supabase sync job).
# Get these from your Supabase project's Settings > API page.
# Changing VITE_SUPABASE_URL/VITE_SUPABASE_ANON_KEY in dashboard/.env requires
# rebuilding the dashboard Docker image, not just restarting it (Vite inlines
# build-time env vars).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
